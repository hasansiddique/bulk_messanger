# Railway / production API environment variables
#
# Required at RUNTIME (set in Railway → Service → Variables).
# The build uses SKIP_ENV_VALIDATION=1 via railpack.json / build:api so these
# are not required during the image build step.

DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-secure-32-character-minimum-secret

# Public URL of this API service (no trailing slash)
BETTER_AUTH_URL=https://your-api.up.railway.app
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app

# Optional — WhatsApp, Redis, etc. (see workspace root .env.example)
# WHATSAPP_ACCESS_TOKEN=
# REDIS_URL=
