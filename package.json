{
  "name": "@bulk-messanger/source",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "nx run-many -t serve --projects=api,web,mobile --parallel=3",
    "dev:api": "nx serve api",
    "dev:web": "nx serve web",
    "dev:mobile": "nx serve mobile",
    "build": "nx run-many -t build --all",
    "build:api": "nx run database:generate && SKIP_ENV_VALIDATION=1 nx build api",
    "start": "sh -c 'cd apps/api && ../../node_modules/.bin/next start --hostname 0.0.0.0 --port \"${PORT:-3000}\"'",
    "start:api": "pnpm start",
    "postinstall": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "db:generate": "nx run database:generate",
    "db:push": "nx run database:push",
    "db:studio": "nx run database:studio",
    "mobile:sync": "nx run mobile:cap-sync",
    "mobile:sync:dev": "CAPACITOR_LIVE_RELOAD=true nx run mobile:cap-sync",
    "mobile:ios": "nx run mobile:cap-open-ios",
    "mobile:android": "nx run mobile:cap-open-android",
    "mobile:add-ios": "nx run mobile:cap-add-ios",
    "mobile:add-android": "nx run mobile:cap-add-android"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@nx/js": "22.7.5",
    "@nx/next": "22.7.5",
    "@nx/react": "22.7.5",
    "@nx/vite": "22.7.5",
    "@nx/web": "22.7.5",
    "@nx/workspace": "22.7.5",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/ui": "~4.1.0",
    "autoprefixer": "10.4.13",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "22.7.5",
    "postcss": "8.4.38",
    "prettier": "~3.6.2",
    "prisma": "^6.19.3",
    "tailwindcss": "3.4.3",
    "tslib": "^2.3.0",
    "typescript": "~5.8.3",
    "vite": "^8.0.0",
    "vitest": "~4.1.0"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ],
    "overrides": {
      "ioredis": "^5.11.1"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-contacts": "^8.0.13",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.4.0",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.101.0",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "better-auth": "^1.6.14",
    "bullmq": "^5.78.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "kysely": "0.28.5",
    "lucide-react": "^1.17.0",
    "next": "~16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.77.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "6.30.3",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
