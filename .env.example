# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bulk_messanger?schema=public"

# Better Auth
BETTER_AUTH_SECRET="replace-with-a-secure-32-character-minimum-secret"
BETTER_AUTH_URL="http://localhost:3000"

# API / Client URLs
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Vite apps (web + mobile)
VITE_API_URL="http://localhost:3000"

# WhatsApp Cloud API (Meta Graph API)
WHATSAPP_ACCESS_TOKEN="your-meta-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_BUSINESS_ACCOUNT_ID="your-waba-id"
WHATSAPP_TEMPLATE_NAME="your-approved-template-name"
WHATSAPP_TEMPLATE_LANGUAGE="en_US"
WHATSAPP_MESSAGES_PER_SECOND=20

# Redis (BullMQ message queue)
REDIS_HOST="localhost"
REDIS_PORT=6379
# REDIS_URL="redis://localhost:6379"

# Optional: extra CORS origins (comma-separated)
# CORS_ALLOWED_ORIGINS="http://192.168.1.4:4200,http://192.168.1.4:4300"

# Optional: skip env validation during CI/Railway builds (runtime still needs real values below)
# SKIP_ENV_VALIDATION=1
